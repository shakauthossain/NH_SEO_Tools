# =============================================================================
# Antigravity SEO — Frontend Environment Variables (Example)
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your real values in .env
# 3. Never commit .env — it is already in .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# Backend API
# The base URL of the FastAPI backend server.
#
#   Local dev        →  http://localhost:8000
#   Docker Compose   →  http://backend:8000   (use service name inside network)
#   Production       →  https://api.yourdomain.com
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# Google Gemini API Key
# Used by @google/genai for any AI-powered analysis features.
# Get your key at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here


# -----------------------------------------------------------------------------
# Vite / Dev-server flags (optional)
# DISABLE_HMR — set to "true" to turn off Hot Module Replacement.
#               Useful inside AI Studio or when running agent-based edits.
# -----------------------------------------------------------------------------
DISABLE_HMR=false
